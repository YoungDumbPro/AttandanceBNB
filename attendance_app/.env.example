# Example environment variables for attendance_app
# Copy this file to .env and fill in production values.

# Flask settings
FLASK_APP=run.py
FLASK_ENV=development
PORT=5001

# Security
SECRET_KEY=replace-with-a-long-random-secret

# Database connection
# For Neon Postgres, use the provided connection string and add sslmode=require if needed.
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require
